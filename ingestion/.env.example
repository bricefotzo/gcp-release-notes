# Copy to .env for local testing (python-dotenv loads it automatically
# if you add `from dotenv import load_dotenv; load_dotenv()` — or just
# export these before running `python main.py` locally).

# "bigquery" (recommended, structured/reliable) or "rss" (best-effort, see
# src/sources/rss_source.py)
SOURCE_MODE=bigquery

# Public source — leave as-is
SOURCE_PROJECT_ID=bigquery-public-data
SOURCE_DATASET_ID=google_cloud_release_notes
SOURCE_TABLE_ID=release_notes
RSS_FEED_URL=https://cloud.google.com/feeds/gcp-release-notes.xml

# Your own project — this is where the ingested rows land, and what gets
# billed for the BigQuery jobs this script runs.
DEST_PROJECT_ID=your-gcp-project-id
DEST_DATASET_ID=gcp_release_notes
DEST_TABLE_ID=release_notes
DEST_LOCATION=US

WATERMARK_OVERLAP_DAYS=3
INITIAL_BACKFILL_DAYS=730
