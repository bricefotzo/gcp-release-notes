# LLM Provider Configuration
# Set to 'gemini' to use Google Gemini, or 'local' to use the local model runner (Ollama / Llama 3.2)
LLM_PROVIDER=local

# If using Gemini, paste your Gemini API key here
GEMINI_API_KEY=

# Optional: Specify the Gemini model (defaults to gemini-1.5-flash)
GEMINI_MODEL=gemini-1.5-flash
